  m_TableData:
  - m_Id: 401539072
    m_Localized: "\u0423\u0434\u0430\u0440 \u0441 \u0440\u0443\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 422510592
    m_Localized: "\u041D\u0430\u043D\u043E\u0441\u0438\u0442 \u0441\u0438\u043B\u044C\u043D\u044B\u0439
      \u043E\u0434\u0438\u043D\u043E\u0447\u043D\u044B\u0439 \u0443\u0434\u0430\u0440
      \u043F\u043E \u0432\u0440\u0430\u0433\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 422510593
    m_Localized: "\u0412\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 422510594
    m_Localized: "\u041B\u0435\u0447\u0438\u0442 \u0432\u0441\u0435\u0445 \u0433\u0435\u0440\u043E\u0435\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 422510595
    m_Localized: "\u0420\u0432\u0430\u043D\u0430\u044F \u0440\u0430\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 422510596
    m_Localized: "\u041D\u0430\u043D\u043E\u0441\u0438\u0442 \u0443\u0440\u043E\u043D
      \u0438 \u0432\u0435\u0448\u0430\u0435\u0442 \u043A\u0440\u043E\u0432\u043E\u0442\u0435\u0447\u0435\u043D\u0438\u0435
      \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0445\u043E\u0434\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 422510597
    m_Localized: "\u041F\u0440\u043E\u0440\u044B\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 422510598
    m_Localized: "\u0414\u043E\u0431\u0438\u0440\u0430\u0435\u0442 \u043A\u0430\u0440\u0442\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 422510599
    m_Localized: "\u0417\u0430\u0449\u0438\u0442\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 422510600
    m_Localized: "\u0414\u0430\u0451\u0442 \u0433\u0435\u0440\u043E\u044E \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
      \u0431\u0440\u043E\u043D\u044E \u0434\u043E \u043A\u043E\u043D\u0446\u0430
      \u0431\u043E\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 422510601
    m_Localized: "\u041E\u0441\u043A\u043E\u043B\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 422510602
    m_Localized: "\u0410\u0442\u0430\u043A\u0443\u0435\u0442 \u0432\u0441\u0435\u0445
      \u0432\u0440\u0430\u0433\u043E\u0432 \u0441\u0440\u0430\u0437\u0443; \u0445\u043E\u0440\u043E\u0448\u0430
      \u043F\u0440\u043E\u0442\u0438\u0432 \u0441\u0432\u044F\u0437\u043E\u043A \u0441\u043E
      \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 422510603
    m_Localized: "\u041F\u0440\u0438\u043B\u0438\u0432 \u044D\u043D\u0435\u0440\u0433\u0438\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 422510604
    m_Localized: "\u0412\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
      \u044D\u043D\u0435\u0440\u0433\u0438\u044E; \u0447\u0442\u043E\u0431\u044B
      \u0440\u0430\u0437\u044B\u0433\u0440\u0430\u0442\u044C \u0435\u0449\u0451 \u043E\u0434\u043D\u0443
      \u043A\u0430\u0440\u0442\u0443 \u0432 \u0445\u043E\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 422510605
    m_Localized: "\u0421\u043C\u0435\u043D\u0430 \u043B\u0438\u043D\u0438\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 422510606
    m_Localized: "\u041C\u0435\u043D\u044F\u0435\u0442 \u043A\u043B\u0435\u0442\u043A\u0443
      \u0446\u0435\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 422510607
    m_Localized: "\u0416\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 422510608
    m_Localized: "\u0414\u0430\u0451\u0442 \u044D\u0444\u0444\u0435\u043A\u0442 \u0440\u0435\u0433\u0435\u043D\u0435\u0440\u0430\u0446\u0438\u0438;
      \u0432\u044B\u043B\u0435\u0447\u0438\u0432\u0430\u0435\u0442 \u0432 \u043A\u043E\u043D\u0446\u0435
      2\u0445 \u0445\u043E\u0434\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 422510609
    m_Localized: "\u041A\u043E\u043D\u0442\u0443\u0437\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 422510610
    m_Localized: "\u041D\u0430\u043D\u043E\u0441\u0438\u0442 \u0443\u0440\u043E\u043D
      \u0438 \u043E\u0433\u043B\u0443\u0448\u0430\u0435\u0442 \u0446\u0435\u043B\u044C
      \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0445\u043E\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 422510611
    m_Localized: "\u041F\u0440\u0438\u0437\u044B\u0432 \u043A\u043E\u043C\u043F\u0430\u043D\u044C\u043E\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 422510612
    m_Localized: "\u041F\u0440\u0438\u0437\u044B\u0432\u0430\u0435\u0442 \u043A\u043E\u043C\u043F\u0430\u043D\u044C\u043E\u043D\u0430;
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0430\u0442\u0430\u043A\u0443\u0435\u0442
      \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
      \u0432\u0430\u0441 \u043A\u0430\u0436\u0434\u044B\u0439 \u0445\u043E\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 422510613
    m_Localized: "\u0410\u0442\u0430\u043A\u0430 \u043A\u043E\u043C\u043F\u0430\u043D\u044C\u043E\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 422510614
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0430\u044F \u0430\u0442\u0430\u043A\u0430
      \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u043D\u043E\u0433\u043E \u043A\u043E\u043C\u043F\u0430\u043D\u044C\u043E\u043D\u0430."
    m_Metadata:
      m_Items: []
